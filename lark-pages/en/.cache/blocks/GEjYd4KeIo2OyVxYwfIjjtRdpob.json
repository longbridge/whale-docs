","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpQ50SMAmPi0FTxx4YhnIaYb","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: When configuring per-currency limits, you must select the corresponding currency and restrict use to the corresponding market. Configuring an all-currency limit applies the trading limit across different markets; if an all-currency limit is set, per-currency trading limits cannot be configured.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpnhTm3Rb0eAyvPGJcMHqP0e","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpddwTM5a52aHTwk1kdlKUif"],"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpddwTM5a52aHTwk1kdlKUif","block_type":2,"parent_id":"doxjpnhTm3Rb0eAyvPGJcMHqP0e","text":{"elements":[{"text_run":{"content":"Displayed limits will be converted to HKD.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpi6DMs2S0KHzjRS41WytDhc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"18B. Q: If both global limits and client limits exist, how are they evaluated?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpSM4xHfW5jUKbYTdxHaz2dg","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: Limit precedence is: client limits > global limits; security limits > global limits; trader limits > global limits.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpWHBQBbfUjJEfCUrZ0nliVh","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpBVrO9ZUdep2zIYsJ8K7xAf"],"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpBVrO9ZUdep2zIYsJ8K7xAf","block_type":2,"parent_id":"doxjpWHBQBbfUjJEfCUrZ0nliVh","text":{"elements":[{"text_run":{"content":"For example: the global configuration sets the \"Customer buy-rejection limit\" to > 500,000 ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"HKD. User","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" A has configured a \"Customer buy-rejection limit\" of > 400,000 HKD (reject).If User A places a buy order for 410,000, the configured limit is hit and the order will be rejected outright. If User B places a buy order for 410,000, the global configuration is evaluated; since the global limit is not breached, the order will be allowed.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpMecUR4uKlntQeR5c1jkq6g","block_type":3,"heading1":{"elements":[{"text_run":{"content":"18C. Q: A client's cash account balance is positive and the client has not borrowed from the broker; why is the financing quota being consumed?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjp2i6qgjI24yqIbgmx4wBUmf","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: The \"Used financing quota\" under Risk Control Management > Customer Financing includes cash that has been frozen and is not available for use.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"FhcEdnke9oPqsgx7TrPjUlE2pub","block_type":27,"image":{"align":2,"height":1864,"scale":1,"token":"MP8obwgIPogPSGxtowSjpzfZpch","width":3806},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpCGY52YDWIWALunZRNXdWKf","block_type":3,"heading1":{"elements":[{"text_run":{"content":"18D. Q: The subaccount’s total assets are not negative; why is the \"Risk Control Status\" shown as \"Danger\"?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpfpFShNUzgFXDs5mKBk4M2g","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: If the master account's \"Risk Control Status\" is \"Danger\", the subaccount will follow the master account and its \"Risk Control Status\" will be \"Danger\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpEgsXVUudP4rd8GuxLmYwjc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"18E. Q: In Haircut Management, will the index in \"Index Haircut Management\" automatically update the information in the constituent stock list?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpsxga8vVhNVaLrEMBaeOEBg","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: \"Index Haircut Management\" will automatically update information such as constituent stock weights and share quantities.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"ZWZVdyjUXoIha7xHZS4jlm9yp9e","block_type":27,"image":{"align":2,"height":1824,"scale":1,"token":"O7pMbG15Ro4LAwx5LkAjrzUjp7g","width":3798},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpH6SvYCLtq87WaYuX8G5Fee","block_type":3,"heading1":{"elements":[{"text_run":{"content":"18F. Q: In \"Haircut Management\", can cash accounts and margin accounts independently use different haircut percentages for calculations?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"doxjpPbgLd8yAwm0J9QFcZkYCv2","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"A: Cash accounts and margin accounts cannot independently use different haircut percentages for calculation.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Zx4odCia1oZperxcxwFjxVyxpbY","block_type":27,"image":{"align":2,"height":1860,"scale":1,"token":"TTDRb9zYEompr2xoEJbjgvAWpdc","width":3752},"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob"},{"block_id":"HA4zdNtnSoIOOqxGgKSjDEZZpV1","block_type":2,"parent_id":"GEjYd4KeIo2OyVxYwfIjjtRdpob","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}