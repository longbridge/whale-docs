ermines whether commission (OR transaction amount) * rate is used to calculate the commission share amount.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"C9SMdKDsyo7kgxxiC38jFDYMpof"},{"block_id":"doxjpEmJoahZvd9mUjdxS0Br1ff","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Tier calculation basis: determines whether commission (OR transaction amount) is used as the basis for tier division.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"C9SMdKDsyo7kgxxiC38jFDYMpof"},{"block_id":"doxjpSIXV3NQgfiBG8maGjqRLRe","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Cross-tier handling method: determines whether to apply a single rate to the entire calculation basis OR split the basis across multiple tiers for calculation.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"C9SMdKDsyo7kgxxiC38jFDYMpof"},{"block_id":"doxjpczBvbAo2EK2PJ7uVxwMwic","block_type":2,"parent_id":"C9SMdKDsyo7kgxxiC38jFDYMpof","text":{"elements":[{"text_run":{"content":"Notes:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpRCEi4TH8S0ZBci4mb8qoDf","block_type":12,"bullet":{"elements":[{"text_run":{"content":"If the commission-sharing currency differs from the commission currency, the commission share amount will be converted to the commission-sharing currency according to the exchange rate.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"C9SMdKDsyo7kgxxiC38jFDYMpof"},{"block_id":"doxjpT8KUfgWapvezBYfjJdMu