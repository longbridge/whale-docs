:"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpL4OyTXinKfWni9GmGj1Jne","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1 Order Placement Issues","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpxlc9SNVRCnF9Lk5VOoYAXg","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1A Q: How does WTT handle odd-lot trading?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpi7kAKUsLEkkPCsdERWwsBe","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Odd-lot orders can be placed on the \"Trading Page\" (see Figure 17.1A-1) and executed via \"Odd-lot Matching\" (see Figures 17.1A-2 and 17.1A-3).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpvBVgQsuwz3fDOJ5IRXbKod","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpNjz3YJoa6snWWiZ5Udgnkh"],"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpNjz3YJoa6snWWiZ5Udgnkh","block_type":2,"parent_id":"doxjpvBVgQsuwz3fDOJ5IRXbKod","text":{"elements":[{"text_run":{"content":"Odd-lot trading volumes are lower than those for round-lot shares; orders may need to remain on the book for several days before execution.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"ZRdbdaQAVoJU2JxyZ8cj7w6wp6U","block_type":27,"image":{"align":2,"height":938,"scale":1,"token":"WGk9b9RHTo2llAxkNRHjkOUMpdg","width":2908},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpTBBjzcFRtKCHWnex5KYDCe","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"Figure 17.1A-1","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"QAS0dPhyrotjKkxXft3jBHsKp4g","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"JlOjbe8aSoAvMexXDhHj8KWSpBb","width":3024},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjp3BtluI1KvZRZ8CxXTHXFhe","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"Figure 17.1A-2","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"MbUwdzeMro2oy5xb6NWjnWaWpLb","block_type":27,"image":{"align":2,"height":1310,"scale":1,"token":"C8dsbiaCRooh5KxVpzJjgiv8pAg","width":1896},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpUic15w5Cw1oF7wNUNZcwjd","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"Figure 17.1A-3","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpXQn4fRjTFZa2stkDU0qcPf","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1B Q: What does the order rejection reason \"Order Price Far Away From Reference Price\" mean?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpmomCVHtjTXU2ZRH0h4gQjc","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Orders are rejected when the order price is too far from the current market price. Buy-side input prices cannot be higher than the best ask by more than 9 price levels; sell-side input prices cannot be lower than the best bid by more than 9 price levels.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpuf18DFDHjAZl8HJXViS94f","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpZXb87JfE47milCmbY71uPf","doxjp9yuqMS0eLmJxXYDvKS8R1f"],"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpZXb87JfE47milCmbY71uPf","block_type":2,"parent_id":"doxjpuf18DFDHjAZl8HJXViS94f","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp9yuqMS0eLmJxXYDvKS8R1f","block_type":2,"parent_id":"doxjpuf18DFDHjAZl8HJXViS94f","text":{"elements":[{"text_run":{"content":"U.S. warrants are currently not supported for trading; the system will display \"This stock is currently not tradable.\"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpbtfj1kmseLpVJOUYeVktPb","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1C Q: What are the front-end order price limits?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpei0mdwZPHbjm7Cb14lordb","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Buy orders priced lower than the current price by 24 price levels will be stored in the system and released when the market reaches the price.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpFGSCJBdKl5HW6EWRZ6UIjr","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"Orders priced more than 9 price levels above the counterparty price will not be stored in the system and will be sent directly to the exchange; however, they may be rejected by the exchange's price limits.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpvTUieT68Gxc0gkJBDcZuZb","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1D Q: How can client trading of virtual assets or specific securities be restricted?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpTsfFoHGdfuetX8atygznfY","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: On the front end, navigate to \"Trade Query > Securities Restriction\" and click \"Add\" in the top right to add securities to a blacklist to prohibit client trading. Securities can be imported in bulk to apply restrictions. If a blacklist entry does not have associated clients, the restriction defaults to all clients.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpDHlwd0rMVc0fFfzBEEvUKd","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpP2R51njpymqzBJjEXtDgu7"],"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpP2R51njpymqzBJjEXtDgu7","block_type":2,"parent_id":"doxjpDHlwd0rMVc0fFfzBEEvUKd","text":{"elements":[{"text_run":{"content":"If certain clients should be permitted to trade, create a whitelist and add the related clients.For the bulk import template, enter stock codes in the format: 3099.hk","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"YpgXdw5DMoDRB6xaVmBjdIxMpZg","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"HPepbOGdDoPVVxxu2GqjgbVmpTd","width":3024},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpWzo7Zm2Ni79HZlsenHBYQg","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1E Q: In WTT's \"Securities Restriction,\" how is \"Associated Region\" used to distinguish clients?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpPRvakna2drZRauxIZGovKb","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: The associated region is determined by the client's declared country of residence; if absent, by the document issuing country; if that is also absent, by nationality.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Ss5CdQBUyoh89kxeh9gjR6Rfpgs","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"LmYkbo8YaoXMe6xZxD5j5g2Wpig","width":3024},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpSbJPaLRHnpnY5b9dpz5Efe","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1F Q: How can I determine the fees to be charged to a client after placing an order?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjp8mBw0VzyiCJSyAhGYvckJH","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Actual fees can be checked after settlement by reviewing report SDR018 - Bargain Detail Report-HK. Estimated fees are available via the \"Amount Details\" function at the lower right of the front-end order component.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"NRKfdm0KIoyu0DxQXqEjPARxpjz","block_type":27,"image":{"align":2,"height":926,"scale":1,"token":"NgATb93BSoKiWMxWlJVjPJz5pAx","width":1492},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjp3eOVChdzA6xauqqn1gfFzc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1G Q: How are clients notified after forced liquidation?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpxSGoYuR962K6FQau5VVkng","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: The App will send a push notification (see Figure 17.1G-1), and forced liquidation will be indicated on the settlement statement (see Figure 17.1G-2). Margin calls are notified by email and App push notifications (see Figure 17.1G-3).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"QKiWd0u3RocuTCxVQPSjJrVXp2g","block_type":27,"image":{"align":2,"height":600,"scale":1,"token":"LB8ebuqWFocARix6nt0jqEFwpQG","width":642},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjp67AE5ewarYwLVWxucXjphb","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"(Figure 17.1G-1)","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpR9YWuivFaehuHnH6OXrYD5","block_type":27,"image":{"align":2,"height":306,"scale":1,"token":"ZeqibBgrXoang8xM7ZLjenMtp9g","width":1724},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpdMv4hkCJFzliYm84iDqVCb","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"(Figure 17.1G-2)","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"M4H0dIjqcoisISxEUUYjYcAvpAb","block_type":27,"image":{"align":2,"height":1744,"scale":1,"token":"S5fybC5o4o8FK1xcxmHjv26KpNc","width":1364},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpMdu529emZcrAJfCwayGVHe","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"(Figure 17.1G-3)","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpYAeZCBVUnKOnTmRUSAX2Ob","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1H Q: At what distance from the market price will \"Pending Submission\" orders be released to the market?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjpu2aXlb7g9uNg5OVcQhE6Bh","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Pending Submission orders for the Hong Kong Exchange will be released to the market when within 20 price levels of the market price.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpnRdLFKz0uvhEC9wfD6nvZc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17.1I Q: Can the system restrict self-matching trades (a client's own buy order matching their own sell order)?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf"},{"block_id":"doxjp7BsChzj9vvTsg7iLoEuk6t","block_type":2,"parent_id":"GJ8GddmxTo6VrCxNZ6kjroABpMf","text":{"elements":[{"text_run":{"content":"A: Self-matching is restricted. For opposing orders from the same client, if the second order would result in a match at an executable price, the second order will be rejected.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}