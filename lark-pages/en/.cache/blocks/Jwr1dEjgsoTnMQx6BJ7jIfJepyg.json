"style":{"align":1,"folded":false}},"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg"},{"block_id":"doxjp4fm6TzrIUgOojzk8bAaByd","block_type":2,"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg","text":{"elements":[{"text_run":{"content":"A:","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" Manual adjustments can be used for this purpose: one client is debited and the other client is credited.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"JSOLd7tQKoL3NFxA2KVjB77lpJl","block_type":27,"image":{"align":2,"height":1632,"scale":1,"token":"XUswbmsrfov3QHx0co8jYZbapm0","width":3692},"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg"},{"block_id":"doxjpAxOIcXZkZsyKwYDAsoY2kd","block_type":3,"heading1":{"elements":[{"text_run":{"content":"4G Q: How should inter‑client adjustments be reported for over‑the‑counter securities transactions?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg"},{"block_id":"doxjp6YHDvgdApqKNbB0i7so3Pb","block_type":2,"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg","text":{"elements":[{"text_run":{"content":"A:","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" Only physical shares or corporate actions involving stamp duty can generate an OTCR file for upload. For inter‑client adjustments, you can export a blank SDR070 - OTCR Report Excel template and manually fill in the transaction details for reporting.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"LfhPd3OUvowHwJx9DIRjDrnipRd","block_type":27,"image":{"align":2,"height":1102,"scale":