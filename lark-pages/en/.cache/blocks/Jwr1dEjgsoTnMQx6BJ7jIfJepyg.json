":2,"parent_id":"doxjpK0hBesefWkqOmdIunmNxCg","text":{"elements":[{"text_run":{"content":"When an adjustment operation is rejected, the client will not receive a notification.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"VbJmd2maVoioi6x3HaRjBJnnppd","block_type":27,"image":{"align":2,"height":1718,"scale":1,"token":"QML3bDhMOoajBexhSbijdgUGpBb","width":3218},"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg"},{"block_id":"doxjpUBdJsuEaiLxA5pqtE8xivh","block_type":2,"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg","text":{"elements":[{"text_run":{"content":"4A Figure 1","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpn5ARpzU4sTx9qN2GgyJScd","block_type":3,"heading1":{"elements":[{"text_run":{"content":"4B Q: The accounting date options for adjustments only show today and tomorrow — how can I backdate to yesterday?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg"},{"block_id":"doxjpbSQ8ExTyAkeCY9KxEzqkPe","block_type":2,"parent_id":"Jwr1dEjgsoTnMQx6BJ7jIfJepyg","text":{"elements":[{"text_run":{"content":"A:","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" The accounting date is not mandatory and may be left blank (see 4B Figure 1). If you need to restore yesterday’s transaction records, you must perform a settlement reversal (see 4B Figure 2).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"A65edwer9o9AX3xlgAAjkmcbp7d","block_type":27,"image":{"align":2,"height":1792,"scale":1,"token":"P4uxbG4AsohQ4sx1EqF