t > CRS File Generation","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp5XHvhZOdgxgBwJ9s4H9yJe","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Note: The tenant must be granted the following permissions in order to operate the related CRS files.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"NJ19dbEGooq4hZxGTkqj6ls8pue","block_type":27,"image":{"align":1,"height":484,"token":"Dv5wbketqo1Ii9x7Oihjz4tQpXc","width":646},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"DlxBdMeX5oIJHgx3QLqjuzXzpuf","block_type":27,"image":{"align":2,"height":1492,"token":"C0l1bTBzroHikSxQ2GIj7qhlpNf","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpVNFqoE7x9dLaL1FhpvHTtc","block_type":2,"comment_ids":["7610699190393392662"],"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"The overall CRS file operation generally follows the sequence shown below.","text_element_style":{"bold":false,"comment_ids":["7610699190393392662"],"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpM7lLsFsUPjPpfZGhrAhLnc","block_type":27,"image":{"align":2,"height":934,"token":"FBWRbeJ3qoWuf7xbTsSjKrLepJe","width":1674},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpfVDWgmvcNaVZ9NsTF1BQzb","block_type":4,"heading2":{"elements":[{"text_run":{"content":"1. Calculate Income","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpjfdVGapNb6EfuMDWbyLVzb","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"First, click \"Calculate Income\" in the upper right corner. After entering the reporting year and the identifier (company name), a file-generation task will be created (visible in the Tasks List tab).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp2BdeBnT9oBVbc239Q9zDAc","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Note: In the Calculate Income window, the external tax filing website will provide a reference number. The company name must be the brokerage's company name and must match the name used in the external tax filing system.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Ff9edeOTGoEIZxxt1bwjpufyp9d","block_type":27,"image":{"align":2,"height":1492,"token":"CP3KbWL9Jop4wCxsbhqjA3CYpDg","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpqQGBExnhPMprhJluanQYeA","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"A system task will be created at this time. When the system task completes (this may take some time to compile the full-year data), the system will assign a common \"Message Number\" to this batch of CRS data.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"QD51dvawpoUU5wxKqcjjb2DzpO7","block_type":27,"image":{"align":2,"height":1492,"token":"Hr9PbFfodo6F8Nxmdd0j9ba6p4i","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpAxsKAeMSVrDkvb206DJUne","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"You may also click the \"Details\" control to the right of a record in the Tasks List tab; this will automatically switch to the CRS Data tab, where you can view or edit the data.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"WZJTd3b0rooe1vxypaijakOtp2g","block_type":27,"image":{"align":2,"height":1492,"token":"YbiIbg0qloJPX5xpYoZjD89rpKh","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"EtogdHgiZo7xwCxejLUjFXjepEb","block_type":27,"image":{"align":2,"height":1492,"token":"Y0Wmb1eJcotfsaxI4T8jjymspPf","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpuaqzpRZooYQS7TlsAjSLN1","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"You may delete records (not to be submitted) or modify the data as needed.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"CPaNdylSroRC2mxs0KIjWJ3EpJf","block_type":27,"image":{"align":2,"height":1492,"token":"OMFMblvJJowB9yxwb7xjDLjkpsh","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjphF96rnQH9GMpZ59GMntBwb","block_type":4,"heading2":{"elements":[{"text_run":{"content":"2. Generate File","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpi6kMNGUPsAkYi57MP5bs3c","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"After verifying or editing the CRS Data on the CRS Data tab, the system will determine the message status and tag it as:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpspFVBz197LoskNn6rZpzyd","block_type":12,"bullet":{"elements":[{"text_run":{"content":"CRS701 = The message contains new information — indicates new data upload.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpXGfseMABP1uejfbANN8Ngc","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"New message [CRS701]: new[CRS701]","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpvnSgtWWZ9isF0zkcLK7wsg","block_type":12,"bullet":{"elements":[{"text_run":{"content":"CRS702 = The message contains corrections for previously sent information — indicates corrections or deletions.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpZ12fi4QAzErZA24sySOfCb","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Correction message [CRS702]: corrections[CRS702]","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpPGjGWZlfwh6mSa3tm839jc","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"You may query using the following criteria as needed (the following is for reference only):","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp5kdRaZKOavnylYFwHAjROY","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Input: ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"Year / Message Type / Identifier / Batch / Message Number","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" and run the query. The Generate File function will then become available.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"JvbtdIgNxoLRNax4L5ejichopA5","block_type":27,"image":{"align":2,"height":1492,"token":"D8SXbyB9uokCTAxqz5WjIk1Spnf","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpyfe1E41rMs2ZSWzzydAQZc","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Click the \"Generate File\" button in the upper right corner to create a system task that will produce a tax-filing specification document.\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"(Note: this may take some time to compile the full-year data.)","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"HS7Pd1XXpo5FxRxawUGjhmX3pOg","block_type":27,"image":{"align":2,"height":1492,"token":"Eev0b9UFnonpRexDXc3jU8Kyp8f","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjp0EbjV6t9sTAo9IgNiKJvpc","block_type":13,"ordered":{"elements":[{"text_run":{"content":"File Download","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjp0oB1XtEStZxMHvrUSaKFYf","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"When the file-generation task is complete, you may download the archive and upload it to the external website.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp6lxsk9YsXUazXZKEx4KnNd","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"(The system will generate a document with an .xml extension.)","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"IcSIdMYHmo0ODmxtdtBjY7P9pLL","block_type":27,"image":{"align":2,"height":1492,"token":"DHlgblKtaoSbSwxFHp6jfbGXpJy","width":3002},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjp2LPBTdKJHDswxKt5HpAD9r","block_type":27,"image":{"align":2,"height":667,"token":"E8P3bgxTioWLXjxqzRejAGblpvc","width":581},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjpDIWeqmheiAX2JOJjVzDJHg","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Recommendation: Do not edit this file manually; improper modifications may cause the file to fail to meet the required specification and prevent successful upload.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp9JCx4JZU8dy7o9slgHyGNd","block_type":4,"heading2":{"elements":[{"text_run":{"content":"3. Upload Generated File","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe"},{"block_id":"doxjp21P360HrprLugmaUCYwaZb","block_type":2,"parent_id":"QbjPdDeYGo3SgjxgSJfjiJMtpZe","text":{"elements":[{"text_run":{"content":"Upload the generated XML file to the external system. After the external system processes the upload, it will return a file serial number. Upda