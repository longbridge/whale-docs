ions properly.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpARQFTlhubU6PnwwPlpDfag","block_type":30,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","sheet":{"token":"Z5NXsJDzahlkjZtXZxBjTbwRpZH_ivw9ql"}},{"block_id":"doxjpCyfIvJzCBXCpD6TIb1Fb4g","block_type":4,"heading2":{"elements":[{"text_run":{"content":"Broker and Client Relationship Lookup / Operations","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpECVootxmv8lhnPlJ6M5Cxh","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Supports querying the clients under a broker by broker, or directly querying an individual client.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"JOZSdpwiJoyLPLx4y9Cj2tw6psh","block_type":27,"image":{"align":2,"height":636,"token":"UDOYbVLMXohMRPxf6tUjdJE9pEg","width":1280},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjprbIUfedwIrydPonTKk8mTd","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Once a client is found, the operations [Unlink Broker Relationship] and [Transfer to Another Broker] are available.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpXcynXtOYPWYGn1sauUN9qf","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"When changing or assigning a broker for a client, optional email notifications to the client are supported.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Xhq9dhjQVor8DoxGXz7jm70Jppd","block_type":27,"image":{"align":2,"height":636,"token":"Vvo3bHYiKonVf2xHFKcjia3QpOd","width":1280},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpPWnEuxnMgOjn14ufD6n3kg","block_type":5,"heading3":{"elements":[{"text_run":{"content":"Broker Management","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjptJM0upnx5T4E1QBwpGzkLh","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Click \"Create\" in the upper-right corner to create broker information. After successfully creating a broker, the system will automatically synchronize and create a backend user account (the broker account can log in to the WTT client).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"WYuSdeQPLo437Zx1QYIjAXPWp8f","block_type":27,"image":{"align":2,"height":678,"token":"XZ6Xb6JxHopMHRxz9cRjVEMWphh","width":1280},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpeCif1bzGG2mg9fVsyUWfXf","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Note: When creating a broker, the broker's brokerage email address is used as the unique identifier for validation.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpkOQ5FwJglLeUEEcPMyclTf","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"After creation, operations are available in the action area to the right of the displayed record: \"Details\" / \"Edit\" / \"Freeze\" / \"Subordinate Management\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"POzRdLvHQojYgnx0ZbHjyBz3p5g","block_type":27,"image":{"align":2,"height":678,"token":"VzhrbP4gbo5SeuxNNjfjd7h0pvF","width":1280},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjp0GPVOD2hXRJeA4BycgZpbc","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"The \"Edit\" option, when modifying a broker's commission-sharing package, optionally supports synchronizing modifications to the commission-sharing package configurations of that broker's clients.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Uvr2dVNN8ofyzixogmkju7Hzpch","block_type":27,"image":{"align":1,"height":1280,"token":"Hj02bTcRookJgRxdPYGjU40jpLe","width":874},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpWi2VkTp3s5PYyrUomQwizg","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"\"Freeze\": after freezing a broker, that broker will be unable to log in to WTT using their account.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp2dHBPkzhBoMDQ4dfApsvGh","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"\"Subordinate Management\": this function has been migrated to \"Identity Management > Personnel Management\", where you can locate the corresponding broker user to edit \"data permissions\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"S8Vhdkbdgo1F7wxnpdCjjouHpQb","block_type":27,"image":{"align":2,"height":1500,"token":"OqByb3c62oCk2OxysSdjJ3FMprE","width":3010},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpaLJEUvp4mnKQOgGnuYYtmg","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"A new broker configuration has been added under broker management: when opening an account, if a broker is not manually assigned, the system will pre-assign the account to a specified broker.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"BMaadLVTxoCdMUxpTs5jl2nKpGh","block_type":27,"image":{"align":2,"height":1500,"token":"LV3Abn0w8oPBW9xm9SEja3JNpid","width":3010},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpEOGL3XPjYkSFQZxmpSa2Mb","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"In the query component: supports searching by broker ID or broker name.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpI7wfZ7FaFjpcnpbx9qybHf","block_type":5,"heading3":{"elements":[{"text_run":{"content":"Add Commission-Sharing Package","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpmsUhXa7CRrGdFffUlziRbh","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"You can click \"Add\" in the upper-right corner to create a new commission-sharing package.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"PEzndWVAOo8oVExz45Njwmubpqg","block_type":27,"image":{"align":2,"height":1500,"token":"UB5mb13JlofJJLx7r1ujsT5XpCg","width":3010},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpWojESiNpNtH6qkGJelUTbf","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"First, fill in the package's primary information.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpoz8DjPJplRhYqeCIxUO9rd","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Field descriptions:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpMQP3kbbLE355MS2m7cg0qc","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Commission recipient setting (broker-dealer or broker): determines which entity the configured algorithm applies to (which one is calculated first).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjp4QnURc4zcw4bUgbvibAQjd","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Allow loss field: determines the handling when the sharing amount exceeds the commission; if losses are allowed, the calculated amount may exceed the commission.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"CCwhd0ul1o0nKdx7dYAj5zrxpfd","block_type":27,"image":{"align":2,"height":1500,"token":"O2KxbR16qoqMmLxvpwTjJSprpCv","width":3010},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjplEiuaQ4T7kkPArBflO51WW","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"After adding rules, you can set package rules separately for equities, options, and other product types.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpwJJfkoIwKo8CrUA7w14QCc","block_type":2,"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe","text":{"elements":[{"text_run":{"content":"Field descriptions:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpScLLdT6eiAHSi1GvqLXyIb","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Billing method: determines whether the sharing amount is calculated as commission (or trade amount) * rate.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpdwOLGmTQlGI5bqgw6EA3hf","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Tiered calculation basis: determines whether commission or trade amount is used for tier segmentation.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"},{"block_id":"doxjpRL8qW68S0dvwnQ9clZtazb","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Cross-tier processing method: determines whether the calculation basis is applied using a single rate across tiers or split into multiple segments for calculation.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CWwEdRM46onvyTxntnSj8Snkpbe"}]}