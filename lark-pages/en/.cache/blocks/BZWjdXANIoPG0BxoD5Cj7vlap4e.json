":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpOMVVBRFDF4H2zAADl5otLI","block_type":2,"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e","text":{"elements":[{"text_run":{"content":"If the market price is incorrect, you may click \"Edit\"","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp0Aja4GHNqsf1pirmfPyaEf","block_type":3,"comment_ids":["7610746157224070676"],"heading1":{"elements":[{"text_run":{"content":"8C Question: How are the cost, price, and position market value on the statement calculated?","text_element_style":{"bold":false,"comment_ids":["7610746157224070676"],"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e"},{"block_id":"doxjp63kMPn6TEjkigCvudCyZ9b","block_type":2,"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e","text":{"elements":[{"text_run":{"content":"Answer: Statement cost is calculated using diluted cost: (Total buy amount − Total sell amount) / Quantity held. The closing price from \"Price Maintenance\" for bonds is displayed as the price on the statement; the cost is the diluted cost provided above. Position market value equals quantity held × closing price.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpnae3u5ktCUgElDP17sbOve","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpmcaCXVejNRHyQ9mXvqlytd","doxjpGSvcvhI29voJSMRUlACgEb"],"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e"},{"block_id":"doxjpmcaCXVejNRHyQ9mXvqlytd","block_type":2,"parent_id":"doxjpnae3u5ktCUgElDP17sbOve","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpGSvcvhI29voJSMRUlACgEb","block_type":2,"parent_id":"doxjpnae3u5ktCUgElDP17sbOve","text":{"elements":[{"text_run":{"content":"For funds, the closing price is taken from the \"NAV Table.\"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpQA1O9czxAiocEqg5Gg6Qnf","block_type":2,"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e","text":{"elements":[{"text_run":{"content":"Note: The amount entered in an adjustment is the trade amount. If a total cost is specified in the adjustment, that specified value takes precedence; otherwise the calculation will use the closing price (price × quantity).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpCtPsOpcHvFEywdNMnQGmK3","block_type":27,"image":{"align":2,"height":260,"token":"VvWibEZ2BoivGEx62fOjRPW5pRe","width":1368},"parent_id":"BZWjdXANIoPG0BxoD5Cj7vlap4e"}]}