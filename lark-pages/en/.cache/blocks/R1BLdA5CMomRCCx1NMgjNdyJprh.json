omer)","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpER14CAPD2Hfy3rHOuhyqIc","block_type":27,"image":{"align":2,"height":1854,"scale":1,"token":"AyYUbCSLaoFwKBx4p5PjM3TppyS","width":3830},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpNOHCn0HqkEEPmndbTkIFGb","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"Step 2: Confirm the reference exchange rate","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpFgoFAtA9sIxO5JMXVeyUgf","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"After selecting the customer and currency pair, the system automatically provides a reference exchange rate; users can also switch to [Custom Rate] for manual entry","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpoXJpuKUTRNqY9Q8FV3VG78","block_type":27,"image":{"align":2,"height":1772,"scale":1,"token":"Xg6ybCkgNoSHFHxdh4Mjyvkmp3c","width":3328},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpLQ2LBoB143k0M2OJ4jJSje","block_type":27,"image":{"align":2,"height":1776,"scale":1,"token":"J1lKbNSO3oFXJEx8hN6jUCttpZd","width":3322},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpX2S8nFhILGXyzYfHIxZuxh","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"Step 3: Enter the amount","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpAAgHcywKaeYZNM6iMWwPye","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"After confirming the customer, currency pair, and rate, enter the exchange amount. The exchange amount can be specified in either of the following ways:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp3yEpytNn6CHoE1gpDNU0So","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Use the selling currency as the base. Example: Assuming USD to HKD rate = 1:7.8, if the selling amount is 1000 USD, the system will automatically calculate the received amount (HKD) = 7800","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpsnrOZUiWjdlSGH1G34ZbNd","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Use the receiving currency as the base. Example: Assuming USD to HKD rate = 1:7.8, if the receiving amount is 1000 USD, the system will automatically calculate the selling currency (HKD) = 7800","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjp5TZMZhZFVPQDbJza0bKscf","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"After the information is entered correctly, click [Confirm]; a foreign exchange record will be generated on the page.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjphdTjsFEupDoKCwIHfFSJIb","block_type":4,"heading2":{"elements":[{"text_run":{"content":"Processing Applications","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1