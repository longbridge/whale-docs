ode":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpIwzA7kgf0OV5yn1TiUKgMB","block_type":27,"image":{"align":2,"height":1770,"scale":1,"token":"ONZ3bRsphoIQwWxiPgLjqsOHpeg","width":3322},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpcv3RKLI7Ta7m4KkTlhvxac","block_type":3,"heading1":{"elements":[{"text_run":{"content":"Exceptional Exchange Records","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpk1UozuJwXgWKCMddghrPjg","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"If an exchange request is abnormally interrupted due to channel providers, banks, customers, or other reasons, the record can be handled on this page.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpAjZDln6xsTnHnfkLX17stb","block_type":4,"heading2":{"elements":[{"text_run":{"content":"Handling Exception Records","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpK82EtRK2pefAkdFdsJJdMd","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"Step 1: Locate the target record and choose one of three actions in the actions column:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpW9PewNUpFbHsjPd04r9umf","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Mark as Success: Indicates that after manual confirmation the channel exchange order resulted in a change in bank funds, so the channel exchange order status is updated to Success manually","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjp1EXXYTsKdoRD3MYHfQhHP1","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Re-exchange: If confirmation of the channel's exchange order shows the bank-side funds did not change and will not change, but manual confirmation indicates the user needs to be re-exchanged, submit a new channel exchange request","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjp8qmmf9SOAEB1SZ0IaTYvxe","block_type":12,"bullet":{"elements":[{"text_run":{"content":"Mark as Failed: Indicates that after manual confirmation the bank-side funds did not change and will not change going forward, so the channel exchange order status can be updated to Failed manually","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjprehJl6zAw2pEfntdRG4Q6J","block_type":27,"image":{"align":2,"height":1220,"scale":1,"token":"CbshbzWfcodgwRxLK4Jj3iphpYf","width":2366},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpZVPRHvYuZsE70gC0kS66Ec","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"Step 2: Carry out review based on the handling method chosen in Step 1","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpZiwKrb8cKWlV49eaUPiGCe","block_type":27,"image":{"align":2,"height":1198,"scale":1,"token":"PB36b7Q9Goz5MexU2LzjujX9pAd","width":2370},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjpQg1Kk8kQpIzoSSHZcVqFub","block_type":3,"heading1":{"elements":[{"text_run":{"content":"Exchange Profit and Loss","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"},{"block_id":"doxjp7Tb18GC6A4OXtclV6zwJl3","block_type":2,"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh","text":{"elements":[{"text_run":{"content":"Due to timing differences, exchange applications may experience exchange rate fluctuations between submission and completion, which affect the exchanged amount. This page is used to view the exchange profit and loss generated by each exchange application and supports export to the local system.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpL2DBvItIUGncsWUdWIVt5p","block_type":27,"image":{"align":2,"height":1210,"scale":1,"token":"L85HbSeEUoxeIexOSu3jJK0Qpdh","width":2344},"parent_id":"R1BLdA5CMomRCCx1NMgjNdyJprh"}]}