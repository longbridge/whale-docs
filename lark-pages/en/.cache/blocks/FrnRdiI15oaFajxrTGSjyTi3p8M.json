false}}},{"block_id":"doxjpEMKKTShZMGiVXrx8aXuIxI","block_type":3,"heading1":{"elements":[{"text_run":{"content":"5.3B Q: What should be entered for the Back-End Order Number & Back-End Transaction Serial Number?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpYt4NU4obgZ3ms2oZHWsasd","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"A:","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" You may copy and paste the contract number.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjplLaw8K464RHziGqmMPZsae","block_type":3,"heading1":{"elements":[{"text_run":{"content":"5.3C Q: What is the function of the \"Estimate\" in the \"Fee Information\" after supplementing an order?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjp7FBOgOIOBouQ3gmQzig8mh","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"A:","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" Click \"Estimate\" to calculate fees based on the client's charging settings. The \"Billing Amount\" is calculated according to the client's billing configuration under \"Business Parameter Settings > Billing Management\"; if the bill was added manually, the \"Billing Amount\" will be \"0\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpT9VM94GSwKWDNMVLsMHmNd","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"If you wish to waive certain charges, click \"Edit/Delete\" within \"Fee Information.\" After deletion, the \"Billing Amount\" will equal 0 and the fee will be shown in the \"Receivable Amount.\"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpmqn1ReKp2OosJfzGTQjUag","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpYJGcJMPGJSxwoGS7qXHYbf","doxjphjeryGE6WmEZoJ2H1RCVsg"],"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpYJGcJMPGJSxwoGS7qXHYbf","block_type":2,"parent_id":"doxjpmqn1ReKp2OosJfzGTQjUag","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjphjeryGE6WmEZoJ2H1RCVsg","block_type":2,"parent_id":"doxjpmqn1ReKp2OosJfzGTQjUag","text":{"elements":[{"text_run":{"content":"\"Actual Received Amount\" = \"Receivable Amount\" - \"Deduction Amount\"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Feumd8jBMobu8Cxnq1vjYVFGpyg","block_type":27,"image":{"align":2,"height":1508,"token":"WhaUbnHsYoXyXOxYtltjM7I0pNg","width":3022},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpdKFmAOFwozXTYjouY2iBgu","block_type":3,"comment_ids":["7611098520535191061"],"heading1":{"elements":[{"text_run":{"content":"5.3D Q: If a back-end supplemental order has more than one transaction record, how should the \"Back-End Order Number\" and \"Back-End Transaction Serial Number\" be filled in?","text_element_style":{"bold":false,"comment_ids":["7611098520535191061"],"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpbdHMugogefBDSYsVX29k9g","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"A: Enter the same contract number for the \"Back-End Order Number\"; enter different serial numbers for the \"Back-End Transaction Serial Number.\"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjppEyj0lPzfPYy13SQIzfcGh","block_type":27,"image":{"align":2,"height":1598,"token":"Xpo8bANymo20R6xRRY0jcxOwpff","width":2850},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpmm7mb3khT5TawQVwBFsMyf","block_type":3,"heading1":{"elements":[{"text_run":{"content":"5.3E Q: Can over-the-counter derivative products be imported as a \"back-end supplemental order\"?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpBX8acUN1FU8uFd6tVPemOe","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"A: In \"Securities Management > Underlying Management > Private Underlying Library,\" click \"Add Underlying\" to create the underlying (see Figure 5.3E-1).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpA0CPjUfZpsiZExBnfyUxWe","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"Then, in \"Clearing Management > Contract Management,\" when creating the supplemental order, enter the full security code (see Figure 5.3E-2) to proceed with the supplementation.","text_element_style":{"bo