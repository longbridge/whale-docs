:false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"DichdjplFozXEXxngfajjrObp6b","block_type":27,"image":{"align":2,"height":1506,"token":"BsKabP49WoHqSCxVS3Cj1CuXpZd","width":3014},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjppOJIAZzeItvqbLTPdwVGve","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"Figure 5.3A-1","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"EoTNdNYpAonO45xyqiXjL3pPpsc","block_type":27,"image":{"align":2,"height":1506,"token":"AGFSb9KDRokR9pxXP7zjAp9Bpvd","width":3014},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"PfdUdqXnjo8EJrxr0KSj6ZwlpEc","block_type":27,"image":{"align":2,"height":1506,"token":"NzJDbT983oqkCWx9CxhjWeEppve","width":3014},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpkcJMusTBHJfJUNXBxpTK4c","block_type":2,"comment_ids":["7611093245103197716"],"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"Figure 5.3A-2","text_element_style":{"bold":false,"comment_ids":["7611093245103197716"],"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"OmhTdaNmiopm6yxqUSBjoV14plf","block_type":27,"image":{"align":2,"height":1508,"token":"CQslbesTboqFsixDPaujyEg4ptg","width":3022},"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M"},{"block_id":"doxjpHP8PNLNAOFfwkOlQS6Wvcd","block_type":2,"parent_id":"FrnRdiI15oaFajxrTGSjyTi3p8M","text":{"elements":[{"text_run":{"content":"Figure 5.3A-3","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"NCAAdQYkooIyJtxSTLaj3B7Kpge","block_type":27,"image":{"align":2,"height":1506,"token":"XY6IbI2RGoO8SsxNJg4jUglOpEd","width":3014},"parent_id