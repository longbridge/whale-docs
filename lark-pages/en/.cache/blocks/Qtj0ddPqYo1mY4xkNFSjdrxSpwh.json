t_run":{"content":"1.1.3 Online Account Opening","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpoakBseolbQ3LKsbHf4MfIh","block_type":3,"heading1":{"elements":[{"text_run":{"content":"1.1.3A Q: How do I perform online transfer verification for account opening?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpwDI1A1F4Y8itP8fATtiz4c","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"A: Select the \"Direct Credit\" method for account funding when opening the account. See the following steps (Verification type — Online Banking Transfer).","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpukH1Zy3kzAFIAJGvReE3ph","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpwSzzAWmKvIVoFgzCRM6Yed","doxjpWbFn8OIll7iUlZGAHlKbwz"],"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpwSzzAWmKvIVoFgzCRM6Yed","block_type":2,"parent_id":"doxjpukH1Zy3kzAFIAJGvReE3ph","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpWbFn8OIll7iUlZGAHlKbwz","block_type":2,"parent_id":"doxjpukH1Zy3kzAFIAJGvReE3ph","text":{"elements":[{"text_run":{"content":"Clients who verify account opening via bank transfer may only transfer funds from Hong Kong banks.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpchu54f9d8Tw4JSqZIYiLlb","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(i) On the \"KYC > Account Opening List\" page, locate the client who applied to open an account. In the action column, click \"Details\"; after confirming that the client's submitted information is correct, click \"Approve Initial Review\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"DXqpdM9OcooYKOx3SYWjPdMFpXd","block_type":27,"image":{"align":2,"height":824,"scale":1,"token":"IpYKb4Mt6opgdMx1hldj3niWpTf","width":2992},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"Rab4drq7RoCGmxx4DaGjNMByp5c","block_type":27,"image":{"align":2,"height":1396,"scale":1,"token":"D91wbmOQbohLZ0x19ZVj28GYpVb","width":2796},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjp6UDqRSJzH8rCDwIHUHfdMd","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(ii) On the \"Funds Management > Deposits > Deposit Applications\" page, locate the client's deposit application and click \"Direct Credit\"; after confirming that the deposit information is correct, click \"Submit for Approval\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"B5VedyrodobwW2xNsB6jsMjKp1c","block_type":27,"image":{"align":2,"height":1094,"scale":1,"token":"WBcYbmyAioCC7zxqhz5joF4ypUe","width":3204},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"PSs4d5Q7voYaQCx731Jj4AsXpxh","block_type":27,"image":{"align":2,"height":1262,"scale":1,"token":"GlDkb9NbaoXhNHxb5nYjlSxHpCb","width":2816},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpFqRnSnod624Kdo6mPOhPUc","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(iii) Navigate to the \"Deposit Review > Opening\" page and click \"Approve\" in the action column.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"Q7K7dfeaHoX8i3xR211jjmUhpJf","block_type":27,"image":{"align":2,"height":686,"scale":1,"token":"TFXNbsE9Ooi7exxezoZjDVd5pDp","width":3202},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjp3sMUSHZZuiMoPOAatqVbVb","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(iv) On the \"Deposit Review\" page, reconfirm that the client's deposit transfer information is accurate, then click \"Approve\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"C9jhdQO2rocY6axfIrTjN50Dp6g","block_type":27,"image":{"align":2,"height":1258,"scale":1,"token":"HF6XbLDnHolID7xpTqqjzXxBplh","width":2794},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpPEk1q8vjiDKDZNZET4WWje","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(v) The reviewer will see an approval notification in the top right; then click \"Approve\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"DP3GdGgpGo3i0sxFU8wj2qhyp7g","block_type":27,"image":{"align":2,"height":1286,"scale":1,"token":"Ulubb7Mn3oK4O3xDoEWjWrv0pjb","width":2828},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpdJfSfbSTbAq69wTkbilf0c","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(vi) Return to the \"KYC > Account Opening List\" page, locate the client, and click \"Details\" to enter the \"Account Opening Details\" page. Click \"Approve RO Approval\" and then \"Confirm\".","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"AQkjd9uhXoZ6TYxeRp5ji0kLpJb","block_type":27,"image":{"align":2,"height":1080,"scale":1,"token":"IBDubLzqpoJMtHxvVq1j0SrApfd","width":2768},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"ScuQdoWSQo8UdGxxzS5j2pMAp2n","block_type":27,"image":{"align":2,"height":940,"scale":1,"token":"YKl1bOwW7oLUt1xj72jjEISSpzh","width":1702},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpGCch3MMdWaH7l8oRbpa2je","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"(vii) The account status will update to \"Activated,\" and the client will receive an account activation notification in the APP and may begin using the account.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpJ7Ieidq5FI53Tu1SGdBKce","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpnn60HwlrdFguRrEs8Er4pN","doxjp2RMc6GoIL3tOtETNY8TIBd"],"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpnn60HwlrdFguRrEs8Er4pN","block_type":2,"parent_id":"doxjpJ7Ieidq5FI53Tu1SGdBKce","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp2RMc6GoIL3tOtETNY8TIBd","block_type":2,"parent_id":"doxjpJ7Ieidq5FI53Tu1SGdBKce","text":{"elements":[{"text_run":{"content":"Clients who verify account opening via bank transfer may only transfer funds from Hong Kong banks.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"WuGFdaOsxoOU7yx6JkEjvveNpef","block_type":27,"image":{"align":2,"height":758,"scale":1,"token":"A1sobeeP2odR5SxNarGj8MCApOf","width":3004},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjphjAO8yFIpyMEjTYf01n61d","block_type":3,"heading1":{"elements":[{"text_run":{"content":"1.1.3B Q: If an account opening application is rejected, will the client receive a notification?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpIAC3wtPKBHOI1jGt3fwFPd","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"A: For online applications, a rejected action will generate an email and an App push notification; the rejection can be configured to return the application to a specified page. Offline applications do not generate notifications.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpOZ8EIxIbCES2AlLvy6Zz7b","block_type":3,"heading1":{"elements":[{"text_run":{"content":"1.1.3C Q: To change the witness method for account opening, to which page should the application be rejected?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpmH2p7KsFzIyHfhsGpUR6Mg","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"A: On the \"KYC > Account Opening List\" details page, click \"Reject\" and you may tick the \"Document Upload Page\" option to return the application to the client for modification. (See 1.1.3C Figure 1.)\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"Or enter the rejection details in \"Remarks,\" then on the \"Reject Page\" select \"Document Upload Page\" to return the account opening application. (See 1.1.3C Figure 2.)","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"HBN6dI0H8oHo9XxdYdpjBsNCp9e","block_type":27,"image":{"align":2,"height":1342,"scale":1,"token":"Ih4RbaYzworJhuxmoVbjuY32pTh","width":3224},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpxgG4q6N2y23Qtlg6unR5Pb","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"1.1.3C Figure 1","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"JambdpoL6oKG86xF0kNjG2zAp9g","block_type":27,"image":{"align":2,"height":1358,"scale":1,"token":"C9okbpjOioLjmrxOf0wjbq8xp9e","width":2940},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpLfbHX2C3CBsG7yMkP8Rgkd","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"1.1.3C Figure 2","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpSPblWcW0kVfaENNhz9VBue","block_type":3,"heading1":{"elements":[{"text_run":{"content":"1.1.3D Q: Can a rejected client modify their information?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpqRr7TuKMp5GhDKJXP3hxge","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"A: For offline account opening, you can perform \"Reject\" and then click \"Edit\" on the \"KYC > Account Opening Details\" page to modify the information. For online applications, the rejection will be returned to the client to make modifications via the App.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpIC41krLDJRXAGblp8V6s9c","block_type":3,"heading1":{"elements":[{"text_run":{"content":"1.1.3E Q: What is the account opening process for third-party witness?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh"},{"block_id":"doxjpPP8ZoCLIJIk3z04oeav7Ph","block_type":2,"parent_id":"Qtj0ddPqYo1mY4xkNFSjdrxSpwh","text":{"elements":[{"text_run":{"content":"A: If the App selects \"Third‑Party Witness\" on the \"Account Information Preparation\" page, prompt the client to prepare the required account opening documents and related materials, then click \"Next — Mail Documents.\"\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"On the \"Mail Documents To\" page, remind the client to mail the documents; after dispatching the documents, click \"Confirm Sent.\" Once the documents are received, upload them in the backend to process the account opening application.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}