HzMjGZUXpXb"},{"block_id":"doxjpkGuIdwDSashjOnOGWgNpob","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17A Question: How can the front-end view the names of the primary and secondary holders in joint account information?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpP6CIBPrgMau0vqRzNXOkcg","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: In the \"Customer Information\" component, click the \"...\" settings in the upper-right and enable the option to display joint account information.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"EEMqdJz0XoCZJIxwn6zj0MK9phd","block_type":27,"image":{"align":2,"height":528,"scale":1,"token":"MEtQbnBtco93Twx98dzjhu2Tp4A","width":2894},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"NqYTd7aDeo40YVxIQq6jA9Htpaf","block_type":27,"image":{"align":2,"height":996,"scale":1,"token":"JwMEb1dE2oihMIxmOcYjdq55pzc","width":1492},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpGP1l9frg4sOtvRNCWDcFDO","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17B Question: What is the \"Reset Current Layout\" feature?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpI2Z2OMJRNJVMc7s8VI5bId","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: \"Reset Current Layout\" restores the layout to its initial state. This feature is only available on system base pages (e.g., Stock, Quotes, Trading); it is not available on custom pages.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"NKX3d1qGHozDdzxomhfjDziWpjg","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"B7TZbRAgkoMO4QxLTMIjYRjipmb","width":3024},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"YRdodEV2MoOY2CxfdYCjG6gepQg","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"Hoi8bmGTnoaiBrxcNruj80Dcpwd","width":3024},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpyQRXxvD7pV6OHXSsfewWyc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17C Question: Does WTT's \"Save All Layouts\" require saving each page individually?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpBk0LSS34A6u1NHBjVDhnaf","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: Use the component toolbox in the upper-right: Layout Management > Save All Layouts to save the entire WTT layout. You do not need to save each page individually.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"S77udciaVocuCaxeokcjG5XqpQg","block_type":27,"image":{"align":2,"height":920,"scale":1,"token":"Gp8ubCl86oj9L6xvwibjWvZspie","width":1360},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpX692vm7iahe5nAYbgId7Pb","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17D Question: How is the Net Asset Ratio calculated?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpu0XQzPCXewtJxwpJBJvtTb","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: Net Asset Ratio = Equity Assets / Total Market Value of Holdings.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"Equity Assets = Total Cash + Total Market Value of Holdings.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp4vsDge1VbpXZUj16MGz3Ld","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjp7zNtop2La58ER3SojseXCd"],"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjp7zNtop2La58ER3SojseXCd","block_type":2,"parent_id":"doxjp4vsDge1VbpXZUj16MGz3Ld","text":{"elements":[{"text_run":{"content":"The Total Market Value of Holdings includes the market value of stocks and options.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"JYuWdU6PkoOvsDxSMAAjbToupeb","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"GpzhbokqXoKOMTx946sjjOVtpth","width":3024},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpAHyKfIWkM6WhD6EoUMFSrd","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17E Question: How do I apply for market data in WTT?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpqGB7M3rqzGeb6OV54N68kd","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: Click \"Market Data Application\" in the top-right of WTT, then select the market and data plan in the \"Market Data Store.\" After approval, charges will be billed on Whale's monthly invoice according to usage.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"RQkbd9ZCdodMS8xdjfSjO1ZYpVb","block_type":27,"image":{"align":2,"height":1888,"scale":1,"token":"UzsBbmcBconAjHx6QRJjvTKspLg","width":3022},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpGomAK19EYqSpF7DYxkX3Se","block_type":3,"heading1":{"elements":[{"text_run":{"content":"17F Question: If the front-end market view is set to 40 broker levels for bids and asks, how is the \"40 levels\" calculated?","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjptk5KVynnyxwu5OsP7udQy8","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"text_run":{"content":"Answer: The broker bid/ask depth contains a list of the top 40 broker IDs in the buy/sell direction:","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpsfJI6lQpk9tKZBuXBvwYNe","block_type":12,"bullet":{"elements":[{"text_run":{"content":"If more than 40 brokers are present at a single price level, the page displays the first 40 brokers.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpDYHt8rXYimjmhYixAx1Bgd","block_type":12,"bullet":{"elements":[{"text_run":{"content":"If fewer than 40 brokers are present at a single price level, then:\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"40 = Number of Brokers + Number of Price Levels with Brokers + Number of Price Levels without Brokers * 2.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpXG9727mwNCsdebNPQLXXUh","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"gift","text_color":1},"children":["doxjpd5QUGZewsO5RIHHnGUi0Nd"],"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"doxjpd5QUGZewsO5RIHHnGUi0Nd","block_type":2,"parent_id":"doxjpXG9727mwNCsdebNPQLXXUh","text":{"elements":[{"text_run":{"content":"Note: Under exchange rules, a price level with no brokers occupies two rows: one row indicates the distance from the reference price, and the other row indicates that there are no brokers at that price.","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"GiJwdJPXBoO2s5xSb15jLCrSpPw","block_type":24,"children":["U2bMd4ESVoB5jrxUsOLjJeFopae","GHhTd4xQio6IfGxOCIOjpBbDpUF"],"grid":{"column_size":2},"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb"},{"block_id":"U2bMd4ESVoB5jrxUsOLjJeFopae","block_type":25,"children":["VABEdXusZodyVsxkeVjjSLPcpJh"],"grid_column":{"width_ratio":51},"parent_id":"GiJwdJPXBoO2s5xSb15jLCrSpPw"},{"block_id":"VABEdXusZodyVsxkeVjjSLPcpJh","block_type":27,"image":{"align":2,"height":572,"scale":0.6033057851239669,"token":"BhZ8bZkenouIgLxbgeRjKjicpPh","width":1210},"parent_id":"U2bMd4ESVoB5jrxUsOLjJeFopae"},{"block_id":"GHhTd4xQio6IfGxOCIOjpBbDpUF","block_type":25,"children":["SnqydK3NmoroA6x4aWmjjBx8pvc"],"grid_column":{"width_ratio":48},"parent_id":"GiJwdJPXBoO2s5xSb15jLCrSpPw"},{"block_id":"SnqydK3NmoroA6x4aWmjjBx8pvc","block_type":27,"image":{"align":2,"height":484,"scale":0.7464212678936605,"token":"CBwWbyhEnoELICx4j0FjA4Dbptk","width":978},"parent_id":"GHhTd4xQio6IfGxOCIOjpBbDpUF"},{"block_id":"V0TNduP45ogqIFx5XhAjraB2pxh","block_type":2,"parent_id":"W8BAdvtvxoCqPFxeHzMjGZUXpXb","text":{"elements":[{"t