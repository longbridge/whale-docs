d","block_type":12,"bullet":{"elements":[{"text_run":{"content":"業務本質","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：通過區塊鏈網絡廣播交易，實現數字資產所有權的跨地址轉移，需依賴平台審核與鏈上確認雙重機制保障安全。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpI1ZYJrKvosOJOApiwVceue","block_type":12,"bullet":{"elements":[{"text_run":{"content":"常見場景","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：資產劃轉（平台間轉移）、個人儲存（轉入硬件錢包）、交易支付（轉至對方地址）、法幣兌現（先轉至支持提現的平台）等。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpMFf8lwtzPmpRoIP3fs7s4d","block_type":12,"bullet":{"elements":[{"text_run":{"content":"關鍵規則","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：需匹配幣種對應的區塊鏈網絡（如 USDT 的 ERC-20/TRC-20），且受平台 KYC 認證、提幣限額、安全驗證等規則約束。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpNNsx2SIRdmRlsCKm1iskrc","block_type":3,"heading1":{"elements":[{"text_run":{"content":"出币步骤","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpFNBh8RW7pT2OmyOP5ODlec","block_type":2,"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg","text":{"elements":[{"text_run":{"content":"出币業務的基本流程：","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpGJmLWtqHKbXxEuFKCaBWbc","block_type":13,"ordered":{"elements":[{"text_run":{"content":"前置準備：確認基礎條件","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpQ1x85kycJavRVeXqzAHqEh","block_type":13,"ordered":{"elements":[{"text_run":{"content":"發起出币申請（以交易平台為例）","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpDHMYtz2eFu6TSZ7vyK5pjz","block_type":13,"ordered":{"elements":[{"text_run":{"content":"完成安全驗證與提交","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjp0Vy0NpRt0fCoEwqA4qksWq","block_type":13,"ordered":{"elements":[{"text_run":{"content":"WBO 工單審批流程","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpzCt7nUKpr3INLoBjQxbE3b","block_type":13,"ordered":{"elements":[{"text_run":{"content":"等待平台審核與鏈上確認","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpx1scAdJk62hD3SardNQ8Ve","block_type":13,"ordered":{"elements":[{"text_run":{"content":"確認到账狀態","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpUtn3z3G7LgRubT4mpJW1qg","block_type":19,"callout":{"background_color":5,"border_color":5,"emoji_id":"round_pushpin","text_color":1},"children":["doxjpvsOVuJvDa25U6jqaada12d"],"parent_id":"VaQndEfsyoGoS1xzdyBjlmVGpeg"},{"block_id":"doxjpvsOVuJvDa25U6jqaada12d","block_type":2,"parent_id":"doxjpUtn3z3G7LgRubT4mpJW1qg","text":{"elements":[{"text_run":{"content":"注意：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" 虛擬幣帳戶以「加密貨幣 + 計價貨幣」組合標的記帳：入幣、出幣時按加密貨幣單獨記錄，最終同步至證券帳戶時，以該組合標的入帳（例：加密貨幣 ETH，預設計價貨幣 USD，入帳標的為「VA/HAS/ETHUSD」）。出帳時優先抵扣可用餘額較大的幣種，若餘額不足則自動從次優先級幣種扣減。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}