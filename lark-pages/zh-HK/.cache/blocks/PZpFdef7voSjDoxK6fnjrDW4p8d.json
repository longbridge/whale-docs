},{"block_id":"doxjpiy881bMtCgocJflh4aezrc","block_type":2,"parent_id":"doxjpeSfVezJyjA0KfTFCvMYIvb","text":{"elements":[{"text_run":{"content":"注意：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" 虛擬幣帳戶以「加密貨幣 + 計價貨幣」組合標的記帳：入幣、出幣時按加密貨幣單獨記錄，最終同步至證券帳戶時，以該組合標的入帳（例：加密貨幣 ETH，預設計價貨幣 USD，入帳標的為「VA/HAS/ETHUSD」）。出帳時優先抵扣可用餘額較大的幣種，若餘額不足則自動從次優先級幣種扣減。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"WQWrdNBBwoFFg5xmIvMj0vgLpRf","block_type":2,"parent_id":"PZpFdef7voSjDoxK6fnjrDW4p8d","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}