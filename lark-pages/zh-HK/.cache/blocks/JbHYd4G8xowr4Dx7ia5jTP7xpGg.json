hrough":false,"underline":false}}},{"text_run":{"content":"請參考 HKIDR 操作文檔  ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"mention_doc":{"obj_type":22,"text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false},"title":"HKIDR 操作文檔 ✅","token":"URxzd1F0moX0KtxlBrrja0U4pZb","url":"https://longbridge-group.jp.larksuite.com/docx/URxzd1F0moX0KtxlBrrja0U4pZb"}},{"text_run":{"content":"。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"QeFod324AoWFknxlXUTjvJQ3pfb","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"U7U7dMBCyotlfAxalJKjQHQIprg","block_type":4,"heading2":{"elements":[{"text_run":{"content":"1.5B 問：申報 BCAN 的時間點是什麼？","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg"},{"block_id":"JMMOd0oKyo5xiUxywGRj9nTfpSf","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"答：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"券商為交易所參與者（EP），自動申報 HKIDR，系統發送時間點為 8:00， 12:00， 15:00， 16:15。\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"如非交易所參與者，需要自行下載申報文件到 HKEX（在「賬户管理＞BCAN 碼＞HKIDR 報送」頁面下載申報文件（見 1.5B 圖一）。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"CLcTdMxxLoScllxfEakjwAkUpyg","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"晚上 HKEX 返回的全景文件導入系統中，如沒問題，客户狀態更新為已生效。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"AHMRdc7cko7M58xK9s8j2D7aplz","block_type":27,"image":{"align":2,"height":1292,"token":"LvRzbJZmNo3QTYxHL4ijy1l2pOf","width":2508},"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg"},{"block_id":"QWl1dK2ckof3zHxDrI8jsLlwpMq","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"1.5B 圖一","text_element_style":{"bold":false,"inline_code":false,"italic":true,"strikethrough":false,"underline":false}}}],"style":{"align":2,"folded":false}}},{"block_id":"F6cDdBZkroSbrIxYYXZjXBK5pKg","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"DGeCdl9d1oEu2hx5QsgjoBXCppc","block_type":4,"heading2":{"elements":[{"text_run":{"content":"1.5C 問：客户的港股通狀態為未生效，會否影響到下單交易？及 什麼時候會更新為已生效？","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg"},{"block_id":"JyxCdjUI6o13DNxZI9ejAlfHpwe","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"答：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"HKIDR 每天下午 4:30 交易所就停止申報了，在這個時間點後的開戶，要在第二天作報送。\n在 HKIDR 未生效而同意了港股交易狀態下，不會影響到客戶的買單和賣單交易。\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"HKIDR 文件上傳等到晚上約 6:00 後，交易所處理完成，返回全景文件到系統後，才會變更為已生效狀態。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"BhQMd6McooHUEGxLcGwjSBIDpyf","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"RjA3dUcRAoNQqCxcMAbjpvMep3x","block_type":4,"heading2":{"elements":[{"text_run":{"content":"1.5D 問：申報 BCAN 後，為什麼顯示未生效？","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg"},{"block_id":"GUOzdhJDzoSzFYxbODaj02ESpQh","block_type":27,"image":{"align":2,"height":1018,"token":"QHoCbymEVoMfbtxib0NjRKzJpPc","width":2842},"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg"},{"block_id":"ZoG1dDDdVoO8v3xD1kujJk4gpGc","block_type":2,"parent_id":"JbHYd4G8xowr4Dx7ia5jTP7xpGg","text":{"elements":[{"text_run":{"content":"答：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"資料缺失的會申報失效，申報 BCAN 的必要字段可參考「賬户管理＞BCAN 碼＞BCAN 列表」（姓名、證件號、證件類型、證件簽發地）","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"\n","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"如：主子賬户的會跟隨主申請賬户顯示。\n如：聯名帳戶的次要持有人沒有填身份證明的必要字段，會引致 BCAN 未能生效。\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"交易所參與者（EP） 在當天 4：15 前，補回次要持有人的身份文件資料，再申報 BCAN。待交易所確認後，BCAN 便會生效。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}