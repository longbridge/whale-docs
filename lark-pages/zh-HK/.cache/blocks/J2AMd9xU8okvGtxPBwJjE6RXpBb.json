eading3":{"elements":[{"text_run":{"content":"操作步驟","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"J2AMd9xU8okvGtxPBwJjE6RXpBb"},{"block_id":"doxjpQzmuYPMdJgrnQPhJ3508Wg","block_type":13,"ordered":{"elements":[{"text_run":{"content":"觸發地址認證","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：充值時，如果你的充值來源地址為個人錢包地址，且地址未經 HashKey PRO 認證，則你的虛擬資產將在獲得一定數量的區塊確認後自動觸發地址認證。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"J2AMd9xU8okvGtxPBwJjE6RXpBb"},{"block_id":"doxjpw5hhNsksIGwXDv6Gk7C7Zg","block_type":13,"ordered":{"elements":[{"text_run":{"content":"選擇認證方式","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：以 Metamask 錢包為例，在添加充值白名單頁面選擇 MetaMask 認證方式，點擊【連接 MetaMask】。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"J2AMd9xU8okvGtxPBwJjE6RXpBb"},{"block_id":"doxjp35087obkugDHdvFS7U7Tbh","block_type":13,"ordered":{"elements":[{"text_run":{"content":"連接錢包","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：彈出錢包連接界面，確認需要認證的錢包地址，點擊【下一步】，再點擊【連接】。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"J2AMd9xU8okvGtxPBwJjE6RXpBb"},{"block_id":"doxjpxZeaCfVYnWOTMA6bHwXvnf","block_type":13,"ordered":{"elements":[{"text_run":{"content":"小額支付驗證","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：在「客