nline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpjyONMyxeDOgw5atjEFqjkf"},{"block_id":"doxjpNsLPF7jGE3HbGqW3MX51vc","block_type":27,"image":{"align":2,"height":2457,"token":"GBdebXi74oYd7ExbRpVjJFuqpsh","width":2356},"parent_id":"UG7Ld45p6oFEgXx1DLRjYKknpHf"},{"block_id":"doxjpqfx5XGh6Q9tE17KIeYjTpg","block_type":12,"bullet":{"elements":[{"text_run":{"content":"駁回（","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"可批量操作","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"）：若客戶遞交證券取出申請資料有誤或使用者反饋本次申請無效時，操作員可以進行【駁回】操作","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"UG7Ld45p6oFEgXx1DLRjYKknpHf"},{"block_id":"doxjp63mWCGjQkJqrwrTh4Qfzrh","block_type":12,"bullet":{"elements":[{"text_run":{"content":"通知券商：由於轉倉業務需要對方券商的配合，在實際操作過程中，為了能夠順利轉出，用戶通常會聯絡券商及時處理。此功能將提供郵件發送功能，並根據郵件發送的結果顯示給用戶是否已經通知了券商，以便於用戶進一步處理業務。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"children":["doxjpssNbodAcF5QtTdasKoLm3d","doxjp7vVNyRCcWnY2isMJDDFPTY","doxjphiEmn9WsZ7rxGcMcyMLPUj","doxjpbmfo8ioQF0G7oem1uIewNd"],"parent_id":"UG7Ld45p6oFEgXx1DLRjYKknpHf"},{"block_id":"doxjpssNbodAcF5QtTdasKoLm3d","block_type":12,"bullet":{"elements":[{"text_run":{"content":"選擇需要寄送郵件的券商機構，系統會自動帶出對方券商的郵件地址，操作員可檢查郵箱是否正確","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjp63mWCGjQkJqrwrTh4Qfzrh"},{"block_id":"doxjp7vVNyRCcWnY2isMJDDFPTY","block_type":12,"bullet":{"elements":[{"text_run":{"content":"選擇目標券商下的涉及到的證券取出申請明細（已發送過的證券申請將被剔除）","text_eleme