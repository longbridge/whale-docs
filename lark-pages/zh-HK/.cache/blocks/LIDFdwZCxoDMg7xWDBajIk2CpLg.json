"round_pushpin","text_color":1},"children":["doxjp82usdiU464F5UjffvW2KYb"],"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjp82usdiU464F5UjffvW2KYb","block_type":2,"parent_id":"doxjpCzlJbLuvnC5J31lzr2MxGe","text":{"elements":[{"text_run":{"content":"菜單入口：證券管理-證券存入","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp4btfU7IbUdRF9IDyiVNmLc","block_type":4,"heading2":{"elements":[{"text_run":{"content":"存入申請","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpkykhKmRVInk9ZseujbG1Ge","block_type":2,"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg","text":{"elements":[{"text_run":{"content":"證券存入申請為用戶方提出，申請的內容包含了券商資訊、帳戶資訊、證券詳情與備註4大部分。WHALE使用者可以手動幫助客戶進行證券入倉并根據客戶提交的申請進行駁回、提交審批、通知券商等操作。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpKsEOQG1IFi5YCNFD9Crdyc","block_type":12,"bullet":{"elements":[{"text_run":{"content":"手工入倉","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpJqEZCznDEjBOim9u3DZvMf","block_type":2,"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg","text":{"elements":[{"text_run":{"content":"適用於使用者聯絡後台操作員進行手動新增轉入申請記錄的場景，操作員需要依序填寫客戶的證券資訊、帳戶資訊以及證券的明細資訊。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpHCWDGLgB891KbM00Exih47","block_type":27,"image":{"align":2,"height":2469,"token":"Dqw0b7Q7Do8183xz8jqj86PGpUF","width":2076},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjp7aQZLAe1cYA0NZkan6zedb","block_type":12,"bullet":{"elements":[{"text_run":{"content":"如轉入的股票爲實物股票，則在“是否爲實物股票”點選是","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpSvG0lsEHWwEtW9jdrST1Mf","block_type":12,"bullet":{"elements":[{"text_run":{"content":"駁回（","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"可批量操作）","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：若客戶遞交證券存入申請資料有誤或使用者反饋本次申請無效時，操作員可以進行【駁回】操作","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpA9yY23k9mPGhynmrrudooh","block_type":12,"bullet":{"elements":[{"text_run":{"content":"通知券商：由於轉倉業務需要對方券商的配合，在實際操作過程中，為了能夠順利轉入，用戶通常會聯絡券商及時處理。此功能將提供郵件發送功能，並根據郵件發送的結果顯示給用戶是否已經通知了券商，以便於用戶進一步處理業務。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"children":["doxjpA2tyz057IWiRn5ms5M8Yoc","doxjpdCjuvOJgmSBMFeNB1vcvih","doxjp7atLg862W7ZNXRThIHoXyr","doxjpTUHmLi4S48RMQd8rimZU2n"],"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpA2tyz057IWiRn5ms5M8Yoc","block_type":12,"bullet":{"elements":[{"text_run":{"content":"選擇需要寄送郵件的券商機構，系統會自動帶出對方券商的郵件地址，操作員可檢查郵箱是否正確","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpA9yY23k9mPGhynmrrudooh"},{"block_id":"doxjpdCjuvOJgmSBMFeNB1vcvih","block_type":12,"bullet":{"elements":[{"text_run":{"content":"選擇目標券商下的涉及到的證券轉入申請明細（已發送過的證券申請將被剔除）","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpA9yY23k9mPGhynmrrudooh"},{"block_id":"doxjp7atLg862W7ZNXRThIHoXyr","block_type":12,"bullet":{"elements":[{"text_run":{"content":"預覽郵件內容，確認無誤後點選發送","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpA9yY23k9mPGhynmrrudooh"},{"block_id":"doxjpTUHmLi4S48RMQd8rimZU2n","block_type":12,"bullet":{"elements":[{"text_run":{"content":"至郵件發送記錄頁面中查看發送狀態","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpA9yY23k9mPGhynmrrudooh"},{"block_id":"doxjpLwj56IJrZVw25psnnkzU3f","block_type":27,"image":{"align":2,"height":1330,"token":"Jauyb29gIo323axMoV1jMmqOpEc","width":2858},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpoqrgDGgk28RjQNEjp2dKIh","block_type":27,"image":{"align":2,"height":1332,"token":"BAlpbt6UKo2YHwxozcNjqh13pge","width":2856},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpoWfQk8AHCiu2Z9JcwEmRZg","block_type":27,"image":{"align":2,"height":599,"token":"AHdVblzLFo09qoxGPNPjfCxpp5g","width":1280},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpm6OJJpERUZpcy3yOUm3OTe","block_type":27,"image":{"align":2,"height":624,"token":"KErDb91zgogYC9xqF8fjjXbQp4c","width":1280},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpdpJs2k2Ucvtm8yshc8eanh","block_type":12,"bullet":{"elements":[{"text_run":{"content":"提交（","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"可批量操作）","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：經過操作人員初步審查無誤後，可以將申請提交至下一節點的操作人員進行審核-入倉操作","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpj2g2mhQ2uwvO1tgFuyOjpb","block_type":12,"bullet":{"elements":[{"text_run":{"content":"編輯：若操作員在處理轉入申請時，從客戶方得知券商已通知或未通知的信息，可以透過【編輯】按鈕進行修改通知狀態，以保證對方券商是否知曉需要處理證券轉倉的信息與實際情況相符","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpuXK0wNdVyvi3ufKmzeAvZd","block_type":27,"image":{"align":2,"height":1380,"token":"BBqRbC6V5oYXKVxJ58DjiTCcpfg","width":3830},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpdBDFzm5Y1dBeCCgBioon6b","block_type":12,"bullet":{"elements":[{"text_run":{"content":"指標卡","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpp1abS4bGHOZ8jw8Dxp10Kc","block_type":2,"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg","text":{"elements":[{"text_run":{"content":"若券商的證券轉入業務量較大，可以透過系統的分類展示卡進行精細化作業，指標卡的左右排布反映了業務操作的先後順序","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjp3ANLNVIi84kH1BcIyRtISR","block_type":27,"image":{"align":2,"height":1780,"token":"TFESbDmehoZKI2xIqXSjwuyUpqf","width":3818},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpJoe3yFyhRU9yB2R62tESwh","block_type":4,"heading2":{"elements":[{"text_run":{"content":"存入明細","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjp9W5NXYeyVyiy60hHgFj9ge","block_type":2,"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg","text":{"elements":[{"text_run":{"content":"由於一個存入申請下可能存在多筆證券明細記錄，具體操作入倉的審核人員需要針對每筆存入明細進行仔細核對，審核通過後方可入倉。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"doxjpt6o9dWlBzYRsC84RJ4e1Fd","block_type":12,"bullet":{"elements":[{"text_run":{"content":"修改：若在處理證券明細時，發現用戶提交的某筆具體的明細記錄有問題，可在與客戶確認無誤後可以透過【編輯】按鈕進行修正","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"children":["doxjpg1ngizWgj83b1gNBEVKPae","doxjplvrVCK8TV2V60f4JJes7eg"],"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpg1ngizWgj83b1gNBEVKPae","block_type":27,"image":{"align":2,"height":1058,"token":"C8XfblSpBo6Wj4xY7SVjQ3mopgg","width":3768},"parent_id":"doxjpt6o9dWlBzYRsC84RJ4e1Fd"},{"block_id":"doxjplvrVCK8TV2V60f4JJes7eg","block_type":12,"bullet":{"elements":[{"text_run":{"content":"修改的范围：股票名稱、託管商編號、子倉編號、證券明細數量、轉入成本、結單備註","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"doxjpt6o9dWlBzYRsC84RJ4e1Fd"},{"block_id":"doxjpG7dB7GXQuolOTDMf2zptYw","block_type":12,"bullet":{"elements":[{"text_run":{"content":"删除：若在證券明細時，用戶反映提交的某筆具體的明細記錄不再進行轉入，可以透過【删除】按鈕直接刪除目標明細記錄","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"LIDFdwZCxoDMg7xWDBajIk2CpLg"},{"block_id":"doxjpchSxwLbMXNzhtuA9P4vRoh","block_type":12,"bullet":{"elements":[{"text_run":{"content":"生成SI指令（","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"可批量操作）","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"：由於轉倉業務需要在CCASS裡填寫必要的SI信息，生成SI指令功能可以將這些必要的信息以文件的形式自動保存，供用戶進行上傳CCASS，以免於手動在CCASS系統錄入。產生的SI指令也可以在「SI指令清單」選單下