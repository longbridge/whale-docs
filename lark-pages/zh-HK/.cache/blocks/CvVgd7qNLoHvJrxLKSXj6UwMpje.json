"CvVgd7qNLoHvJrxLKSXj6UwMpje","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"ClXddz74posVT7xaen9jhVctpRh","block_type":4,"heading2":{"elements":[{"text_run":{"content":"14C 問：為什麼我 Statement 裡面的資料遺失了幾天？ ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje"},{"block_id":"DOLNdlMs6o10r4xT5T8jmvnTpJb","block_type":2,"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje","text":{"elements":[{"text_run":{"content":"答：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"日結單、月結單沒有生成，就不會有結單資料的備份。日結單生成的前提是當天有資金／持倉變動。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"V7cWd37hDoPpRyxvC10jXcV5pmg","block_type":2,"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"HkmhdYsnYoER3fxCQHfjyq4Npyh","block_type":4,"heading2":{"elements":[{"text_run":{"content":"14D 問：為什麼我的 Log 目錄資料遺失了幾天？ ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}},"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje"},{"block_id":"Q6uPdxWMXoJiryxBx4wjIkWDphb","block_type":2,"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje","text":{"elements":[{"text_run":{"content":"答：","text_element_style":{"bold":true,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"目前僅為租用戶開通了 ","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"bingo,member-auth,msg-box,togo-proxy","text_element_style":{"bold":false,"inline_code":true,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":" 四個服務的日誌會上傳到 SFTP。\n","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}},{"text_run":{"content":"另外，我們預設為租戶保存最近 14 天的日誌，超過 14 天的日誌會看不到記錄。","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}},{"block_id":"PfSIdh9gVoFJiOxX41bjxq33p2T","block_type":2,"parent_id":"CvVgd7qNLoHvJrxLKSXj6UwMpje","text":{"elements":[{"text_run":{"content":"","text_element_style":{"bold":false,"inline_code":false,"italic":false,"strikethrough":false,"underline":false}}}],"style":{"align":1,"folded":false}}}]}